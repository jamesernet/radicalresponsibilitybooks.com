<nav class="site-nav" id="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="{{ site.site.title }} — Home">
      {{ site.nav.logo }}
    </a>

    <!-- Desktop nav -->
    <div class="nav-right">
      {% for link in site.nav.links %}
        <a href="{{ link.href }}" class="nav-link">{{ link.label }}</a>
      {% endfor %}
      <a href="{{ site.links.buyBook }}" class="btn btn--solid">{{ site.cta.buyLabelShort }}</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" id="nav-toggle" aria-expanded="false" aria-controls="nav-mobile-menu" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile pop-out panel + backdrop -->
<div class="nav-backdrop" id="nav-backdrop" aria-hidden="true"></div>
<aside class="nav-panel" id="nav-mobile-menu" aria-hidden="true" aria-label="Mobile menu">
  <div class="nav-panel__inner">
    {% for link in site.nav.links %}
      <a href="{{ link.href }}" class="nav-panel__link">{{ link.label }}</a>
    {% endfor %}
    <div class="nav-panel__divider"></div>
    <a href="{{ site.links.instagram }}" class="nav-panel__social" target="_blank" rel="noopener">Instagram</a>
    <a href="{{ site.links.linkedin }}" class="nav-panel__social" target="_blank" rel="noopener">LinkedIn</a>
    <a href="{{ site.links.youtube }}" class="nav-panel__social" target="_blank" rel="noopener">YouTube</a>
    <a href="{{ site.links.buyBook }}" class="btn btn--primary nav-panel__cta">{{ site.cta.buyLabel }}</a>
  </div>
</aside>
